## 핵심 실행 흐름

### 1. 프로그램 시작 (main.py)

```python
async def main():
    bot = TradingBot()
    await bot.initialize()      # API, DB, 텔레그램 연결
    await bot.restore_state()   # 상태 복원
    await bot.run()             # 메인 루프 시작
```

### 2. 상태 복원 (시작 시)

```python
# core/helpers/state_restoration_helper.py
async def restore_state():
    # 1. 후보 종목 복원
    candidates = db.get_candidate_stocks(today)
    for stock in candidates:
        trading_manager.add_selected_stock(stock)
    
    # 2. 포지션 복원
    positions = db.get_open_positions()
    for pos in positions:
        trading_stock = trading_manager.get_stock(pos.stock_code)
        trading_stock.set_position(pos.quantity, pos.buy_price)
        trading_stock.target_profit_rate = pos.target_profit_rate  # ⭐
        trading_stock.stop_loss_rate = pos.stop_loss_rate          # ⭐
```

### 3. 스크리닝 (08:55)

```python
# core/quant/quant_screening_service.py
async def run_screening():
    # 1. 후보 종목 조회
    candidates = api.get_condition_search()
    
    # 2. 팩터 점수 계산
    for stock in candidates:
        value_score = calculate_value_score(stock)
        quality_score = calculate_quality_score(stock)
        momentum_score = calculate_momentum_score(stock)
        growth_score = calculate_growth_score(stock)
        
        total_score = (
            value_score * 0.25 +
            quality_score * 0.25 +
            momentum_score * 0.30 +
            growth_score * 0.20
        )
    
    # 3. 상위 30개 선정
    top_30 = sorted(scores, reverse=True)[:30]
    
    # 4. DB 저장
    db.save_quant_portfolio(top_30)
    db.save_factor_scores(top_30)
```

### 4. 리밸런싱 (09:05)

```python
# core/helpers/rebalancing_executor.py
async def execute_rebalancing():
    # 1. 계획 수립
    plan = rebalancing_service.plan_rebalancing()
    
    # 2. 매도 실행
    for stock in plan.sell_list:
        order_manager.place_market_order(stock, 'SELL')
    
    # 3. 유지 종목 갱신
    for stock in plan.keep_list:
        new_profit_rate, new_loss_rate = calculator.calculate(
            rank=stock.new_rank,
            total_score=stock.new_score,
            momentum_score=stock.new_momentum
        )
        trading_stock.target_profit_rate = new_profit_rate
        trading_stock.stop_loss_rate = new_loss_rate
    
    # 4. 매수 실행
    for stock in plan.buy_list:
        profit_rate, loss_rate = calculator.calculate(...)
        order_manager.place_market_order(stock, 'BUY')
        db.save_virtual_buy(
            stock_code=stock.code,
            target_profit_rate=profit_rate,  # ⭐ DB 저장
            stop_loss_rate=loss_rate         # ⭐ DB 저장
        )
```

### 5. 장중 모니터링 (1분마다)

```python
# core/trading_stock_manager.py
async def start_monitoring():
    while is_market_open():
        for stock in portfolio:
            # 현재가 조회
            current_price = api.get_current_price(stock.code)
            
            # 수익률 계산
            profit_rate = (current_price - stock.buy_price) / stock.buy_price
            
            # 익절 체크
            if profit_rate >= stock.target_profit_rate:
                order_manager.place_market_order(stock, 'SELL')
                db.save_virtual_sell(profit_loss=..., reason="익절")
            
            # 손절 체크
            if profit_rate <= -stock.stop_loss_rate:
                order_manager.place_market_order(stock, 'SELL')
                db.save_virtual_sell(profit_loss=..., reason="손절")
        
        await asyncio.sleep(60)  # 1분 대기
```

